{
  "name": "@ai-sync/mcp-server",
  "version": "1.0.0",
  "description": "MCP server exposing .ai-sync/ protocol as structured tools for cross-platform AI agent synchronization",
  "type": "module",
  "license": "MIT",
  "bin": {
    "ai-sync-mcp": "./bin/ai-sync-mcp.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
