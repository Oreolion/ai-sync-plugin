    "directory": "packages/mcp-server"
  },
  "author": "oreolion",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "glob": "^10.3.12",
    "gray-matter": "^4.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
