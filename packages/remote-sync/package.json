{
  "name": "@oreolion/ai-sync-remote",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers API for ai-sync team handoff synchronization",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute ai-sync --file=./migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 execute ai-sync --local --file=./migrations/0001_initial.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
