{
  "name": "@ai-sync/launch-video",
  "version": "1.0.0",
  "private": true,
  "description": "ai-sync launch video built with Remotion",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render src/index.ts AiSyncLaunch out/ai-sync-launch.mp4",
    "build:gif": "remotion render src/index.ts AiSyncLaunch out/ai-sync-launch.gif --image-format png",
    "preview": "remotion preview src/index.ts"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/paths": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
